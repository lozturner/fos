%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#cce3de', 'primaryTextColor': '#3a3a3a', 'primaryBorderColor': '#6b9080', 'lineColor': '#6b9080', 'secondaryColor': '#eae4e9', 'tertiaryColor': '#dda77b' } } }%%

flowchart TD
    SHAREX((ShareX Capture)) --> SAVE["Screenshot saved to\nDocuments/ShareX/Screenshots/%y-%mo/"]

    SAVE --> WATCHDOG{"watchdog detects\nnew .png file"}
    SAVE --> PERFORM{"ShareX PerformActions\ncalls spend-notify.py"}

    PERFORM -->|"POST /api/notify"| WATCH_API
    WATCHDOG --> WATCH_API["spend-watch.pyw\nreceives file path"]

    WATCH_API --> DEDUP{"Hash dedup:\nseen before?"}
    DEDUP -->|Yes| DISCARD["Discard duplicate"]
    DEDUP -->|No| RESIZE["Resize to 1024px\nbase64 encode"]

    RESIZE --> VISION["Claude Vision API\nclaude-haiku-4-5"]

    VISION --> PURCHASE{"Is this a\npurchase?"}
    PURCHASE -->|No| LOG_SKIP["Log as non-purchase\nno action"]
    PURCHASE -->|Yes| EXTRACT["Extract:\nmerchant, amount, currency\ncategory, item, cancel hint"]

    EXTRACT --> PERSIST["Append to\ndetections.jsonl"]
    PERSIST --> SSE["Push via SSE\n/api/events"]
    SSE --> BROWSER["Auto-open browser\nspend-chat.html#detected/id"]

    BROWSER --> LANDING

    subgraph LANDING["Landing"]
        L1["Screenshot thumbnail"]
        L2["Merchant + Amount"]
        L3["Soft entrance animation"]
    end

    LANDING -->|"Tell me about this one"| CONV
    LANDING -->|"Not right now"| PARK["Saved for later\nin timeline"]

    subgraph CONV["Guided Conversation"]
        direction TB
        Q1["What caught your eye\nabout this?"]
        Q1 -->|answer or skip| Q2["How are you feeling\nabout it?"]
        Q2 -->|select or skip| Q3["Was this something\nyou'd been thinking about?"]
        Q3 -->|select or skip| Q4["Anything you want to\nremember about this moment?"]
    end

    CONV --> REFLECT

    subgraph REFLECT["Reflection"]
        R1["Purchase card\nwith your answers"]
        R2["You paused and thought\nabout it. That's the\nwhole skill."]
    end

    REFLECT -->|"Add to my timeline"| TIMELINE
    REFLECT -->|"I want to cancel this"| CANCEL

    subgraph TIMELINE["Timeline"]
        direction LR
        T1["Reverse-chrono\npurchase list"]
        T2["Category badges\n+ running totals"]
        T3["Tap any purchase\nto revisit conversation"]
    end

    TIMELINE -->|"Export"| EXPORT["Download JSONL"]

    subgraph CANCEL["Cancel Help"]
        direction LR
        C1["Known cancel URLs\nAmazon, Netflix, Spotify..."]
        C2["Unknown merchant?\nGoogle search fallback"]
        C3["One tap — you're there"]
    end

    CANCEL --> TIMELINE

    %% ─── WHISPER INTEGRATION (optional) ───
    WHISPER((Whisper Float\nvoice button)) -.->|"voice input\ninto any text field"| Q1
    WHISPER -.->|"voice input"| Q4

    %% ─── DATA PERSISTENCE ───
    subgraph PERSISTENCE["Data Persistence"]
        direction LR
        P1["spend_data/detections.jsonl\nall detections"]
        P2["localStorage spend_current\nauto-save transitions"]
        P3["localStorage spend_sessions\ncompleted conversations"]
        P4["JSONL export\nfor AI consumption"]
    end

    PERSIST -.-> PERSISTENCE
    TIMELINE -.-> PERSISTENCE

    %% ─── ANTI-SHAME LAYER ───
    subgraph ANTI_SHAME["Anti-Shame Messaging Layer"]
        direction LR
        AS1["Curiosity, not judgment"]
        AS2["Every screen has\nan escape route"]
        AS3["No guilt language:\nnever impulse, waste, guilty"]
        AS4["You noticed.\nThat's the whole point."]
    end

    LANDING -.->|"woven throughout"| ANTI_SHAME
    CONV -.->|"woven throughout"| ANTI_SHAME
    REFLECT -.->|"woven throughout"| ANTI_SHAME

    %% ─── STYLING ───
    style LANDING fill:#cce3de,stroke:#6b9080
    style CONV fill:#cce3de,stroke:#6b9080
    style REFLECT fill:#dda77b,stroke:#c4956e
    style TIMELINE fill:#cce3de,stroke:#6b9080
    style CANCEL fill:#eae4e9,stroke:#9a8c98
    style PERSISTENCE fill:#f9e2af,stroke:#dda77b
    style ANTI_SHAME fill:#f0e6d3,stroke:#dda77b
    style DISCARD fill:#eae4e9,stroke:#9a8c98
    style LOG_SKIP fill:#eae4e9,stroke:#9a8c98
    style PARK fill:#eae4e9,stroke:#9a8c98
    style EXPORT fill:#dda77b,stroke:#c4956e
    style SHAREX fill:#cce3de,stroke:#6b9080
    style WHISPER fill:#cce3de,stroke:#6b9080
