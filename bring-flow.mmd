%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#cce3de', 'primaryTextColor': '#3a3a3a', 'primaryBorderColor': '#6b9080', 'lineColor': '#6b9080', 'secondaryColor': '#eae4e9', 'tertiaryColor': '#dda77b' } } }%%

flowchart TD
    START((Open Bring)) --> RECOVER{"Incomplete session?"}
    RECOVER -->|Yes| RECOVER_PROMPT{"Continue or start fresh?"}
    RECOVER -->|No| WELCOME
    RECOVER_PROMPT -->|Continue| RESUME_VIEW
    RECOVER_PROMPT -->|Fresh| WELCOME

    subgraph WELCOME["Welcome"]
        W1["Morning, Loz. Let's get you set up."]
        W1 --> W2["Shows date/time"]
        W2 --> W3["Shows last check-in if exists"]
    end

    WELCOME -->|"Let's go"| FEELING
    WELCOME -->|"Skip to quick capture"| BRAINDUMP

    subgraph FEELING["How are you feeling?"]
        F1["Calm"]
        F2["Tired"]
        F3["Anxious"]
        F4["Overwhelmed"]
        F5["Frozen"]
        F6["Frustrated"]
        F7["Hopeful"]
        F8["Optional free-text elaboration"]
    end

    FEELING --> BRAINDUMP
    FEELING -->|"Skip this"| BRAINDUMP

    subgraph BRAINDUMP["Brain Dump"]
        BD1["Large textarea"]
        BD1 --> BD2["Don't organize. Don't prioritize. Just dump."]
    end

    BRAINDUMP -->|"Done dumping"| MUSTS
    BRAINDUMP -->|"Nothing right now"| MUSTS

    subgraph MUSTS["What MUST happen today?"]
        M1["Shows braindump as reference"]
        M1 --> M2["Type new items or tap from braindump"]
        M2 --> M3["Items appear as chips"]
    end

    MUSTS -->|"That's everything"| WANTS
    MUSTS -->|"Nothing is urgent today"| WANTS

    subgraph WANTS["What do you WANT to happen?"]
        WA1["Same pattern as MUSTS"]
        WA1 --> WA2["Remaining braindump shown"]
    end

    WANTS -->|"That's everything"| CATEGORIZE
    WANTS -->|"No specific wants"| CATEGORIZE

    subgraph CATEGORIZE["Categorize Items"]
        C1["Show one item at a time"]
        C1 --> C2["Tap category badge"]
        C2 --> C3{"More items?"}
        C3 -->|Yes| C1
        C3 -->|No| C4["All categorized"]
    end

    CATEGORIZE --> BLOCKERS
    CATEGORIZE -->|"Skip categorizing"| BLOCKERS

    subgraph BLOCKERS["Blockers"]
        BL1["Is anything blocking you?"]
        BL1 --> BL2["Free-text input"]
        BL2 --> BL3{"Stuck-state detected?"}
    end

    BL3 -->|Yes| UNSTUCK_LINK
    UNSTUCK_LINK["Open unstuck.html"] --> BLOCKERS
    BLOCKERS -->|"Done"| REVIEW
    BLOCKERS -->|"Nothing blocking me"| REVIEW

    subgraph REVIEW["Review Summary"]
        R1["Emotional state badge"]
        R2["Must-do items"]
        R3["Want-to items"]
        R4["Blockers"]
        R1 --> R5{"Edit or confirm?"}
        R2 --> R5
        R3 --> R5
        R4 --> R5
    end

    R5 -->|"Edit feeling"| FEELING
    R5 -->|"Edit musts"| MUSTS
    R5 -->|"Edit wants"| WANTS
    R5 -->|"Edit blockers"| BLOCKERS
    R5 -->|"Looks right"| SAVE

    SAVE["Save to localStorage + bring_sessions"] --> DONE

    subgraph DONE["Completion"]
        D1["You showed up. That's the hard part."]
        D1 --> D2["Session summary"]
        D2 --> D3["Anti-shame encouragement"]
    end

    DONE -->|"Export JSONL"| EXPORT["Download bring-log-YYYY-MM-DD.jsonl"]
    DONE -->|"Copy for AI"| CLIPBOARD["Markdown summary to clipboard"]
    DONE -->|"See patterns"| INSIGHTS
    DONE -->|"Close"| END(("Done"))

    subgraph INSIGHTS["Patterns & Insights"]
        I1["Streak counter"]
        I2["Most common categories"]
        I3["Recurring undone items"]
        I4["Emotional state trends"]
    end

    INSIGHTS -->|"Back"| DONE

    %% ─── DATA FLOW ───
    subgraph PERSISTENCE["Data Persistence"]
        direction LR
        P1["bring_current in localStorage\nauto-saves every transition"]
        P2["bring_sessions in localStorage\ncompleted sessions array"]
        P3["bring-log-*.jsonl export\nfor AI agent consumption"]
        P4["Clipboard markdown\nfor pasting into Claude"]
    end

    SAVE -.-> PERSISTENCE

    %% ─── ANTI-SHAME LAYER ───
    subgraph ANTI_SHAME["Anti-Shame Messaging Layer"]
        direction LR
        AS1["Validation on emotional acknowledgment"]
        AS2["Permission on every escape route"]
        AS3["Encouragement on completion"]
        AS4["No judgment on partial/bailed sessions"]
    end

    FEELING -.->|"woven throughout"| ANTI_SHAME
    DONE -.->|"woven throughout"| ANTI_SHAME
    BLOCKERS -.->|"woven throughout"| ANTI_SHAME

    %% ─── CATEGORY MAPPING ───
    subgraph CATEGORIES["Item Categories"]
        direction LR
        CAT1["email"]
        CAT2["legal"]
        CAT3["household"]
        CAT4["health"]
        CAT5["creative"]
        CAT6["admin"]
        CAT7["financial"]
        CAT8["personal"]
    end

    CATEGORIZE -.-> CATEGORIES

    %% ─── STYLING ───
    style WELCOME fill:#cce3de,stroke:#6b9080
    style FEELING fill:#eae4e9,stroke:#9a8c98
    style BRAINDUMP fill:#cce3de,stroke:#6b9080
    style MUSTS fill:#cce3de,stroke:#6b9080
    style WANTS fill:#cce3de,stroke:#6b9080
    style CATEGORIZE fill:#cce3de,stroke:#6b9080
    style BLOCKERS fill:#eae4e9,stroke:#9a8c98
    style REVIEW fill:#cce3de,stroke:#6b9080
    style DONE fill:#dda77b,stroke:#c4956e
    style INSIGHTS fill:#dda77b,stroke:#c4956e
    style SAVE fill:#a6e3a1,stroke:#6b9080
    style PERSISTENCE fill:#f9e2af,stroke:#dda77b
    style ANTI_SHAME fill:#f0e6d3,stroke:#dda77b
    style CATEGORIES fill:#f7f5f0,stroke:#ccc
    style UNSTUCK_LINK fill:#eae4e9,stroke:#9a8c98
    style END fill:#dda77b,stroke:#c4956e,color:#fff
