%%{ init: { 'theme': 'base', 'themeVariables': { 'primaryColor': '#cce3de', 'primaryTextColor': '#3a3a3a', 'primaryBorderColor': '#6b9080', 'lineColor': '#6b9080', 'secondaryColor': '#eae4e9', 'tertiaryColor': '#dda77b' } } }%%

flowchart TD
    START((Open Prompt Forge)) --> RECOVER{"Incomplete session?"}
    RECOVER -->|Yes| RECOVER_PROMPT{"Continue or start fresh?"}
    RECOVER -->|No| WELCOME
    RECOVER_PROMPT -->|Continue| RESUME_VIEW["Resume at last view"]
    RECOVER_PROMPT -->|Fresh| WELCOME

    subgraph WELCOME["Welcome"]
        W1["Morning/Afternoon, Loz.\nLet's forge a prompt."]
        W1 --> W2["Session count + last forge time"]
        W2 --> W3["Random encouragement"]
    end

    WELCOME -->|"Let's forge"| INPUT
    WELCOME -->|"Browse history"| HISTORY
    WELCOME -->|"Decision helper"| DECISION
    WELCOME -->|"Not right now"| GOODBYE["No pressure. This will be here."]

    subgraph INPUT["Raw Input"]
        I1["Large textarea\nPaste or type anything"]
        I1 --> I2["Live word count"]
        I2 --> I3["Anti-shame:\nDon't organize. Just get it in here."]
    end

    INPUT -->|"Analyze this"| PIPELINE
    INPUT -->|"Not ready yet"| WELCOME

    subgraph PIPELINE["Analysis Pipeline"]
        direction LR
        P1["1. PARSE\nChunk text into\nsemantic units\n(regex classification)"] --> P2["2. DIAGNOSE\nRate each chunk:\nvague, hedging,\nbrief, ambiguous,\nor clear"]
        P2 --> P3["3. GROW\nIdentify missing\nsections, suggest\nexpansions"]
        P3 --> P4["4. ASSEMBLE\nArrange into\ncanonical prompt\nstructure"]
    end

    PIPELINE --> SCORE["Score 0-100\nClarity 20% | Specificity 20%\nCompleteness 25% | Structure 20%\nConstraints 15%"]
    SCORE --> RESULTS

    subgraph RESULTS["Analysis Results"]
        R1["Quality score gauge\nwith dimension breakdown"]
        R1 --> R2["Section detection chips\nCONTEXT, ROLE, TASK,\nCONSTRAINT, OUTPUT_FMT,\nEXAMPLE, TONE"]
        R2 --> R3["Annotated text with\nHemingway-style highlights"]
        R3 --> R4["Suggestion cards\nfor improvements"]
    end

    RESULTS -->|"Forge it"| FORGE
    RESULTS -->|"Edit input"| INPUT

    subgraph FORGE["Assembled Prompt"]
        F1["Editable section cards:\nContext, Role, Task,\nConstraints, Output Format,\nTone, Examples, Notes"]
        F1 --> F2["Each card shows source:\n'from your text' or 'suggested'"]
        F2 --> F3["Re-score button\nfor live quality check"]
    end

    FORGE -->|"Export"| EXPORT
    FORGE -->|"Back to analysis"| RESULTS
    FORGE -->|"Re-score"| SCORE_UPDATE["Recalculate + toast"]

    subgraph EXPORT["Export & Save"]
        E1["Preview: formatted markdown"]
        E1 --> E2["Copy to clipboard"]
        E1 --> E3["Download .prompt.json"]
        E1 --> E4["Download .md"]
        E1 --> E5["Save to history"]
    end

    EXPORT -->|"Forge another"| WELCOME
    EXPORT -->|"Browse history"| HISTORY

    subgraph HISTORY["Prompt History"]
        H1["Reverse-chronological list"]
        H1 --> H2["Score, date, input preview"]
        H2 --> H3["Tap to reload into Forge"]
    end

    HISTORY -->|"Load prompt"| FORGE
    HISTORY -->|"Back"| WELCOME
    HISTORY -->|"Clear history"| CONFIRM["Confirm clear"]

    subgraph DECISION["Decision Framework"]
        D1["The Progression:\nIgnorance → Risk → Certainty"]
        D1 --> D2["Step 1: Name the acts"]
        D2 --> D3["Step 2: Name the states"]
        D3 --> D4["Step 3: Fill cells with values\n(felt quality → numbers)"]
        D4 --> D5["Step 4: Apply decision rule\nmaximin | expected value | best act"]
        D5 --> D6["Key insight:\nBuilding the table IS the tool"]
    end

    DECISION -->|"Copy as markdown"| CLIPBOARD["Framework to clipboard"]
    DECISION -->|"Back"| WELCOME

    %% ─── ANNOTATION SYSTEM ───
    subgraph ANNOTATIONS["Hemingway-Style Annotations"]
        direction LR
        AN1["🟥 Vague\n#f38ba8"]
        AN2["🟧 Hedging\n#fab387"]
        AN3["🟨 Too brief\n#f9e2af"]
        AN4["🟪 Ambiguous\n#cba6f7"]
        AN5["🟩 Clear\n#a6e3a1"]
        AN6["🟦 Missing\n#89b4fa"]
    end

    RESULTS -.->|"inline highlights"| ANNOTATIONS

    %% ─── PROMPT SECTIONS ───
    subgraph SECTIONS["Canonical Prompt Structure"]
        direction LR
        S1["Context"]
        S2["Role"]
        S3["Task"]
        S4["Constraints"]
        S5["Output Format"]
        S6["Tone & Style"]
        S7["Examples"]
        S8["Additional Notes"]
    end

    FORGE -.->|"section order"| SECTIONS

    %% ─── ANTI-SHAME LAYER ───
    subgraph ANTI_SHAME["Anti-Shame Messaging"]
        direction LR
        AS1["Every escape says\n'not ready yet'"]
        AS2["Lowest score =\n'raw material'"]
        AS3["Encouragement\non every screen"]
        AS4["No 'bad' or\n'poor' labels"]
    end

    WELCOME -.->|"woven throughout"| ANTI_SHAME
    RESULTS -.->|"woven throughout"| ANTI_SHAME
    EXPORT -.->|"woven throughout"| ANTI_SHAME

    %% ─── DATA PERSISTENCE ───
    subgraph PERSISTENCE["Data Persistence"]
        direction LR
        PD1["forge_current\nauto-save every\nview transition"]
        PD2["forge_sessions\ncompleted prompts\narray"]
        PD3[".prompt.json\nexport file"]
        PD4["Clipboard\nmarkdown export"]
    end

    EXPORT -.-> PERSISTENCE
    FORGE -.->|"auto-save"| PD1

    %% ─── CANVAS FUTURE ───
    subgraph CANVAS_HOOK["Canvas Mode (future)"]
        direction LR
        CV1["Section position data\n{x, y, w, h} in JSON"]
        CV2["sectionCard() wrapper\nswappable renderer"]
        CV3["Drag-and-drop\nvisual blocks"]
    end

    FORGE -.->|"architected for"| CANVAS_HOOK

    %% ─── AI LAYER FUTURE ───
    subgraph AI_LAYER["AI Enhancement (future)"]
        direction LR
        AI1["Claude API for\nricher diagnostics"]
        AI2["Rewrite suggestions\nper chunk"]
        AI3["Offline heuristics\nas fallback"]
    end

    PIPELINE -.->|"v2: API assist"| AI_LAYER

    %% ─── STYLING ───
    style WELCOME fill:#cce3de,stroke:#6b9080
    style INPUT fill:#cce3de,stroke:#6b9080
    style PIPELINE fill:#eae4e9,stroke:#9a8c98
    style SCORE fill:#eae4e9,stroke:#9a8c98
    style RESULTS fill:#cce3de,stroke:#6b9080
    style FORGE fill:#cce3de,stroke:#6b9080
    style EXPORT fill:#dda77b,stroke:#c4956e
    style HISTORY fill:#cce3de,stroke:#6b9080
    style DECISION fill:#eae4e9,stroke:#9a8c98
    style PERSISTENCE fill:#f9e2af,stroke:#dda77b
    style ANTI_SHAME fill:#f0e6d3,stroke:#dda77b
    style ANNOTATIONS fill:#f7f5f0,stroke:#ccc
    style SECTIONS fill:#f7f5f0,stroke:#ccc
    style AI_LAYER fill:#e8eaf6,stroke:#7986cb
    style CANVAS_HOOK fill:#e8eaf6,stroke:#7986cb
    style GOODBYE fill:#eae4e9,stroke:#9a8c98
    style SCORE_UPDATE fill:#eae4e9,stroke:#9a8c98
    style CONFIRM fill:#eae4e9,stroke:#9a8c98
